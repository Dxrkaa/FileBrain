{
  "name": "filebrain",
  "version": "1.0.0",
  "description": "Universal File Understanding System — Desktop Edition",
  "main": "./out/main/index.js",
  "author": "FileBrain",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dist:win:setup": "node scripts/create-nsh.js && npm run build && electron-builder --config electron-builder.setup.yml",
    "dist:win:portable": "npm run build && electron-builder --config electron-builder.portable.yml",
    "dist:win:all": "node scripts/create-nsh.js && npm run build && electron-builder --config electron-builder.setup.yml && electron-builder --config electron-builder.portable.yml",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.31.0",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@electron/rebuild": "^3.7.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.90.21",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.17.30",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.2",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^5.0.0",
    "clsx": "^2.1.1",
    "electron": "^30.0.1",
    "electron-builder": "^26.7.0",
    "electron-vite": "^4.0.0",
    "lucide-react": "^0.474.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.8.3",
    "wouter": "^3.7.1"
  }
}
